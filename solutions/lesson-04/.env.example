# Copy this file to .env and fill in the values before running docker compose.
# .env is gitignored — never commit real secrets.

# --- Anthropic upstream (main path) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Postgres (gateway auth state, rate limits, spend tables) ---
POSTGRES_PASSWORD=gateway_dev_password

# --- Keycloak admin console (dev mode only — never use in production) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Gateway session security ---
# Generate with: openssl rand -base64 32
GATEWAY_JWT_SECRET=

# --- OIDC client secret ---
# Copy from the Keycloak admin console after Lesson 4:
# Clients -> claude-gateway -> Credentials -> Client secret
OIDC_CLIENT_SECRET=

# --- Amazon Bedrock upstream (Lesson 10 bonus only) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
