# Copy this file to .env and fill in the values before running docker compose.
# .env is gitignored — never commit real secrets.

# --- Anthropic upstream (main path) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Postgres (gateway auth state, rate limits, spend tables) ---
POSTGRES_PASSWORD=gateway_dev_password

# --- Keycloak admin console (dev mode only — never use in production) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Gateway session security ---
# Generate with: openssl rand -base64 32
GATEWAY_JWT_SECRET=

# --- OIDC client secret ---
# Pre-set in keycloak/realm-export.json for this lab. Lesson 4 shows you
# where to find it in the admin console (Clients -> claude-gateway ->
# Credentials) so you know how this works in a real deployment.
OIDC_CLIENT_SECRET=dev-only-claude-gateway-secret

# --- Gateway admin API (spend limits, Lesson 8) ---
# Defaults to a fixed dev-only value in docker-compose.yml if left unset
# here. Must be at least 32 characters. Generate your own with:
# openssl rand -base64 32
GATEWAY_ADMIN_KEY=

# --- Amazon Bedrock upstream (Lesson 10 bonus only) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
